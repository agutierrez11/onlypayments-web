  "ecosistema_pagos_4_partes": {
    "descripcion": "El ecosistema de pagos con tarjeta involucra 4 actores principales: Tarjetahabiente, Comercio, Adquirente/Aggregador, y Emisor. Cada uno cobra comisiones en la cadena.",
    "actores": {
      "tarjetahabiente": {
        "rol": "Cliente que realiza la compra con tarjeta",
        "costo": "Generalmente no paga comisión directa"
      },
      "comercio": {
        "rol": "Tienda o negocio que recibe el pago",
        "costo": "Paga la Tasa de Descuento (MDR) al adquirente/agregador"
      },
      "adquirente": {
        "rol": "Entidad que procesa pagos para el comercio (bancos, procesadores)",
        "costo": "Cobra tasa de descuento al comercio; paga Cuota de Intercambio (CI) al emisor"
      },
      "agregador": {
        "rol": "Intermediario tecnológico que conecta comercios con adquirentes (Stripe, Conekta, etc.)",
        "costo": "Cobra tasa de descuento al comercio; paga tasa más baja al adquirente. Margen = spread"
      },
      "emisor": {
        "rol": "Banco que emitió la tarjeta al tarjetahabiente",
        "costo": "Recibe la Cuota de Intercambio (CI) del adquirente"
      },
      "marca": {
        "rol": "Visa, Mastercard, Amex",
        "costo": "Recibe comisión por transacción procesada"
      }
    },
